#include <stdio.h>
int main()
{
    int decnum, binary[32], j, i=0;
    printf("enter a decimal number: ");
    scanf("%d", &decnum);
    
    if(decnum==0)
    {
        printf("binary=0");
        return 0;
    }
    while(decnum>0)
    {
        binary[i]=decnum%2;
        decnum=decnum/2;
        i++;
    }
    printf("binary= ");
    for(j=i-1; j>=0; j--)
    {
        printf("%d", binary[j]);
    }
    printf("\n");
    return 0;
}
