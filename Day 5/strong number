#include<stdio.h>
#include<math.h>
int main()
{
    int i, num, sum=0, rem, temp;
    printf("enter the number: ");
    scanf("%d", &num);
    temp=num;
    while(num>0)
    {
        rem=num%10;
        int fact=1;
        for(i=1; i<=rem; i++)
        {
          fact=fact*i;
        }
        sum=sum+fact;
        num=num/10;
    }
    if(sum==temp)
    {
        printf("the number is a strong number.");
    }
    else
    {
        printf("the number is not a strong number.");
    }
    return 0;
}
