#include<stdio.h>
#include<math.h>
int main()
{
    int num,num1,num2,rem,c=0,sum=0;
    printf("Enter The Number");
    scanf("%d",&num);
    num1=num;
    while(num>0)
    {
        num=num/10;
        c=c+1;
    }
    num2=num1;
    while(num1>0)
    {
        rem=num1%10;
        sum=sum+pow(rem,c);
        num1=num1/10;
    }
    if(sum==num2)
    {
        printf("The Number is a Armstrong Number");
    }
    else
    {
        printf("The Number is not a Armstrong Number");
    }
    return 0;
}
