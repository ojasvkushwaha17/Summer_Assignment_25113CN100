#include <stdio.h>
int fibonacci(int n)
{
    if(n==0)
    return 0;
    if(n==1)
    return 1;
    int a=0, b=1, c;
    for(int i=3; i<=n; i++)
    {
        c=a+b;
        a=b;
        b=c;
    }
    return c;
}
int main()
{
    int n;
    printf("enter the nth term of series: ");
    scanf("%d", &n);
    printf("the %d term of fibonacci series is: %d\n", n, fibonacci(n));
    return 0;
}
