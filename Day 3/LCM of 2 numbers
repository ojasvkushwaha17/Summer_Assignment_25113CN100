#include<stdio.h>
int LCM(int num1, int num2)
{
    int max;
    max = (num1>num2)?num1:num2;
    while(1)
    {
        if(max%num1==0 && max%num2==0)
        {
            return max;
        }
        max++;
    }
}
int main()
{   
    int num1, num2;
    printf("enter 1st number: ");
    scanf("%d", &num1);
    printf("enter 2nd number: ");
    scanf("%d", &num2);
    printf("LCM of %d and %d is: %d", num1, num2, LCM(num1, num2));
    return 0;
}
